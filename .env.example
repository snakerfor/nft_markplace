# ============================================================
# NFT Marketplace - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# === Deployer Configuration ===
# Private key of the deployer account (without 0x prefix)
PRIVATE_KEY=

# RPC URL for the target network
# Examples:
#   Anvil (local):   http://localhost:8545
#   Sepolia:         https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
#   Mainnet:         https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
RPC_URL=

# === Optional Configuration (Deploy Script) ===
# Royalty receiver address (default: deployer address)
ROYALTY_RECEIVER=

# Platform fee recipient address (default: deployer address)
FEE_RECIPIENT=

# ERC20 Token Configuration
ERC20_NAME=MyToken
ERC20_SYMBOL=MTK
ERC20_SUPPLY=1000000

# === Proxy Addresses (Upgrade Script) ===
# These are required when running the upgrade script
# Fill in after initial deployment
TOKEN_PROXY=
NFT_PROXY=
MARKETPLACE_PROXY=
PRICE_ORACLE=

# === Chainlink Price Feed (Sepolia) ===
# ETH/USD Price Feed address from Chainlink Docs
PRICE_ORACLE_ETH_FEED=0x694AA1769357215DE4FAC081bf1f309aDC325306
